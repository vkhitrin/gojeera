    "description": {
      "type": "doc",
      "version": 1,
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Support investigated repeated brownouts on the Wolfman claw servo pack and traced the issue to undersized power rails in the field cabinet."
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Root cause and mitigation notes were delivered to engineering, and the site was stabilized with a temporary power module replacement."
            }
          ]
        }
      ]
    },
